{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cpideas.example/schemas/uoj-bench-skill-bridge-config-v1.json",
  "title": "UOJ-Bench ICPC Light bridge configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profile",
    "workspace_root",
    "workspace_device",
    "skill_bundle_root",
    "skill_bundle_device",
    "expected_skill_bundle_sha256",
    "agent_command",
    "timeout_seconds",
    "max_candidate_bytes",
    "retain_workspaces"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "profile": {"type": "string", "minLength": 1, "maxLength": 128},
    "workspace_root": {"type": "string", "minLength": 1},
    "workspace_device": {"type": "integer", "minimum": 0},
    "skill_bundle_root": {"type": "string", "minLength": 1},
    "skill_bundle_device": {"type": "integer", "minimum": 0},
    "expected_skill_bundle_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "agent_command": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "timeout_seconds": {"type": "number", "minimum": 1, "maximum": 21600},
    "max_candidate_bytes": {
      "type": "integer",
      "minimum": 1,
      "maximum": 4194304
    },
    "retain_workspaces": {"const": true}
  }
}
